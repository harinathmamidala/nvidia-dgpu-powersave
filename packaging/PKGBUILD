# Maintainer: Your Name <your@email.com>
pkgname=nvidia-dgpu-powersave
pkgver=1.0.0
pkgrel=1
pkgdesc="Automatically unbind NVIDIA dGPU on battery and rebind on AC power for hybrid laptops"
arch=('any')
url="https://github.com/YOURUSERNAME/nvidia-dgpu-powersave"
license=('MIT')
depends=('bash' 'systemd' 'nvidia' 'pciutils' 'psmisc')
optdepends=('nvidia-utils: for nvidia-smi process detection (recommended)')
backup=()
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Main script
    install -Dm755 src/gpu-power.sh \
        "$pkgdir/usr/local/bin/gpu-power.sh"

    # systemd units
    install -Dm644 systemd/gpu-power.service \
        "$pkgdir/usr/lib/systemd/system/gpu-power.service"
    install -Dm644 systemd/gpu-power-boot.service \
        "$pkgdir/usr/lib/systemd/system/gpu-power-boot.service"

    # udev rule
    install -Dm644 udev/99-gpu-power.rules \
        "$pkgdir/usr/lib/udev/rules.d/99-gpu-power.rules"

    # License
    install -Dm644 LICENSE \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
